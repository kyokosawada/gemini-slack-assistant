# Slack — new app in the "Development" workspace (Socket Mode).
# Bot User OAuth Token (Install App page). Starts with xoxb-.
SLACK_BOT_TOKEN=
# App-Level Token, scope connections:write (Basic Information → App-Level Tokens). Starts with xapp-.
SLACK_APP_TOKEN=

# Google Gemini API key (free, from Google AI Studio: https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# Gmail SMTP for sending mail — reuses bot #1's app-password path (no OAuth send scope).
# GMAIL_USER is the address mail is sent from; GMAIL_APP_PASSWORD is a 16-char
# Google App Password (Google Account → Security → 2-Step Verification → App passwords).
GMAIL_USER=
GMAIL_APP_PASSWORD=
