{
  "name": "gemini-slack-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slack AI personal assistant — conversational, tool-using agent over Gmail and Calendar.",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "authorize": "bun run src/google/authorize.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@slack/bolt": "^4.7.3",
    "googleapis": "^173.0.0",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^5"
  }
}
